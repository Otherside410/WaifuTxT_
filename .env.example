# Copy this file to .env on the host and fill in the values.
# .env is gitignored — never commit it.

# --- steam-presence service ---
STEAM_API_KEY=
MATRIX_HOMESERVER=https://matrix.org

# Public URL where the steam-presence service is reachable from the browser.
# In prod behind a reverse proxy, typically: https://your-domain/api/steam
# In local docker (no reverse proxy), use the host-mapped port: http://localhost:8083
PUBLIC_BASE_URL=http://localhost:8083

# Front-end URL the callback redirects back to after linking.
FRONTEND_URL=http://localhost:8082

# CORS origin allowed to call the steam-presence API.
ALLOWED_ORIGIN=http://localhost:8082

# Seconds between Steam API polls.
POLL_INTERVAL_SEC=60
