# Steam Web API key — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Matrix homeserver used to verify access tokens via /_matrix/client/v3/account/whoami
MATRIX_HOMESERVER=https://matrix.org

# Public base URL where this service is reachable from the browser.
# Must be the URL Steam will redirect back to (used as openid.return_to).
# Behind nginx, this is typically https://your-domain/api/steam
PUBLIC_BASE_URL=http://localhost:8083

# Front-end URL to redirect the browser to after a successful Steam link.
# A `?steam=linked` or `?steam=error` query is appended.
FRONTEND_URL=http://localhost:5173

# CORS origin allowed to call /steam/link/start and /steam/status/*
ALLOWED_ORIGIN=http://localhost:5173

# Service port
PORT=3000

# SQLite path (mount a volume here in docker-compose)
DB_PATH=/data/steam-presence.db

# Poll interval in seconds (Steam API rate limit is generous but be reasonable)
POLL_INTERVAL_SEC=60
